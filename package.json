    "start": "npx convex dev",
    "deploy": "npx convex deploy",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "import": "npx convex export --prod --path ./export.zip",
